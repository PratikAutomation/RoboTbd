{
  "schema_version": "1.0",
  "description": "RoboLink Common Schema - normalized from multiple robot vendors",
  "normalization_demo": {
    "ur5_original_format": {
      "node_structure": "obs.state.manipulator.qpos[6], qtorque[6], qvel[6]",
      "position_unit": "radians",
      "torque_unit": "Nm",
      "velocity_unit": "rad/s"
    },
    "so100_original_format": {
      "node_structure": "observation.state[6]",
      "position_unit": "servo_ticks (raw encoder)",
      "torque_unit": "not available",
      "velocity_unit": "not available"
    },
    "common_schema": {
      "position_unit": "radians (always)",
      "torque_unit": "Nm (always, derived from current if needed)",
